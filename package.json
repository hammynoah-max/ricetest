{
  "name": "rice-taste-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "test": "tsc -p tsconfig.test.json && node --test .test-build-cjs/tests/scoring.test.js .test-build-cjs/tests/resultEngine.test.js .test-build-cjs/tests/recommendation.test.js",
    "preview": "vite preview --host 127.0.0.1",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
